##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as /usr/xpg4/bin/sh
#       or /usr/bin/ksh, then to run this script, type that shell name before
#       the whole command line, like:
#
#           ksh Gradle
#
#   (2) The Android Studio "Sync Project with Gradle Files" action will regenerate
#       this script along with gradlew.bat. This stub file is provided so that the
#       project is recognised as a Gradle project on disk; Android Studio will
#       replace it with a fully-fledged wrapper on first sync.
#
##############################################################################

# THIS IS A PLACEHOLDER. The Gradle wrapper JAR (`gradle/wrapper/gradle-wrapper.jar`)
# is a binary file and is not checked into this scaffold. Run
# `gradle wrapper --gradle-version 8.10.2` once (or let Android Studio do it on
# first sync) to materialise the real `gradlew`, `gradlew.bat` and
# `gradle-wrapper.jar`. After that this file will be overwritten with the real
# launcher script and can be committed.

echo "gradlew placeholder: run 'gradle wrapper' or open the project in Android Studio to generate the real wrapper." >&2
exit 1
