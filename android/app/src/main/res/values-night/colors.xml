<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark-mode counterparts to res/values/colors.xml -->
    <color name="brand_background">#111111</color>
    <color name="brand_surface">#1a1a1a</color>
    <color name="brand_foreground">#ffffff</color>

    <color name="twa_status_bar">#111111</color>
    <color name="twa_nav_bar">#111111</color>
    <color name="twa_splash_background">#111111</color>

    <!-- Widget colours (dark). -->
    <color name="widget_background">#1a1a1a</color>
    <color name="widget_foreground">#f5f5f5</color>

    <!-- Today highlight keeps the same blue — it reads cleanly on dark backgrounds. -->
    <color name="widget_today">#1a56db</color>
    <color name="widget_today_text">#ffffff</color>

    <!-- Weekend column shading: a touch lighter than the surface, still subtle. -->
    <color name="widget_weekend">#262626</color>

    <!-- Adjacent-month leading/trailing cells: dimmed grey on dark. -->
    <color name="widget_adjacent">#5c5c5c</color>

    <!-- Custom-date labels: muted blue-grey, lighter than the slate used in light. -->
    <color name="widget_label_muted">#94a3b8</color>

    <!-- Slim divider under the month header. -->
    <color name="widget_divider">#2f2f2f</color>
</resources>
