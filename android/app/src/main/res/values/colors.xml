<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App brand colours — taken from the PWA manifest.json. -->
    <color name="brand_background">#f6f4ef</color>
    <color name="brand_surface">#ffffff</color>
    <color name="brand_foreground">#111111</color>

    <!-- TWA host activity. -->
    <color name="twa_status_bar">#ffffff</color>
    <color name="twa_nav_bar">#ffffff</color>
    <color name="twa_splash_background">#f6f4ef</color>

    <!-- Widget colours (light). -->
    <color name="widget_background">#ffffff</color>
    <color name="widget_foreground">#111111</color>

    <!-- Today highlight (matches the PWA's `--primary` blue). -->
    <color name="widget_today">#1a56db</color>
    <color name="widget_today_text">#ffffff</color>

    <!-- Weekend column shading: very subtle grey, same idea as the print layout. -->
    <color name="widget_weekend">#f0f0f0</color>

    <!-- Adjacent-month leading/trailing cells: greyed-out day numbers, no labels. -->
    <color name="widget_adjacent">#a8a8a8</color>

    <!-- Custom-date labels: muted slate so they read differently from bold black
         holiday labels. Glance doesn't expose italic, so we differentiate by colour. -->
    <color name="widget_label_muted">#64748b</color>

    <!-- Slim divider under the month header. -->
    <color name="widget_divider">#e2e2e2</color>
</resources>
