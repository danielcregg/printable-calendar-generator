<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ backup / device-transfer rules. The TWA's web data lives in Chrome's
    storage area, not the app's, so we have nothing app-private to exclude here.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- include everything by default -->
    </cloud-backup>
    <device-transfer>
        <!-- include everything by default -->
    </device-transfer>
</data-extraction-rules>
