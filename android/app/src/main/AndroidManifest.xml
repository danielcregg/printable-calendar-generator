<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Permissions used by the TWA helper (it talks to Chrome via the Custom Tabs
        protocol, which is implemented over an intent — no INTERNET permission is
        required here, but we declare it for clarity and for any future native HTTP
        calls from the widget data source).
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".PrintableCalendarApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrintableCalendar"
        tools:targetApi="34">

        <!--
            Trusted Web Activity launcher.
            On launch, opens the deployed PWA at twaDefaultUrl with no browser chrome,
            provided /.well-known/assetlinks.json on twaHostName is signed for this APK.
            Without verified asset links, Chrome falls back to a thin Custom Tab URL bar.
        -->
        <activity
            android:name="com.google.androidbrowserhelper.trusted.LauncherActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.PrintableCalendar.Splash">

            <!-- Required by androidbrowserhelper: the URL the TWA opens. -->
            <meta-data
                android:name="android.support.customtabs.trusted.DEFAULT_URL"
                android:value="${twaDefaultUrl}" />

            <!-- Status-bar and nav-bar colours; matches the PWA theme. -->
            <meta-data
                android:name="android.support.customtabs.trusted.STATUS_BAR_COLOR"
                android:resource="@color/twa_status_bar" />
            <meta-data
                android:name="android.support.customtabs.trusted.NAVIGATION_BAR_COLOR"
                android:resource="@color/twa_nav_bar" />

            <!-- Splash screen shown while Chrome warms up. -->
            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_IMAGE_DRAWABLE"
                android:resource="@drawable/splash" />
            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_SCREEN_BACKGROUND_COLOR"
                android:resource="@color/twa_splash_background" />
            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_SCREEN_FADE_OUT_DURATION"
                android:value="300" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Deep-link from the home-screen widget into the TWA. The autoVerify=true
                attribute, combined with /.well-known/assetlinks.json on
                danielcregg.github.io, lets Android open the URL directly in this app
                without a chooser dialog.
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="${twaHostName}"
                    android:pathPrefix="/printable-calendar-generator/" />
            </intent-filter>
        </activity>

        <!--
            The Glance widget receiver. AppWidgetManager calls this when the user adds
            the widget; it returns a GlanceAppWidget that composes the UI as RemoteViews.
        -->
        <receiver
            android:name=".widget.CalendarWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>
    </application>
</manifest>
